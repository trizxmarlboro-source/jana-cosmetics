{
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/[...path].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?path=:path*"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/produto",
      "destination": "/produto.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/minha-conta",
      "destination": "/minha-conta.html"
    },
    {
      "source": "/pedido-confirmado",
      "destination": "/pedido-confirmado.html"
    },
    {
      "source": "/auth",
      "destination": "/auth.html"
    }
  ]
}
